{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Awesome LangChain & LangGraph resource list",
  "type": "object",
  "required": ["version", "lifecycle_stages", "categories"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "lifecycle_stages": {
      "type": "object",
      "propertyNames": { "enum": ["build", "observe", "evaluate", "deploy"] },
      "additionalProperties": { "type": "string" }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "group", "title", "description", "resources"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "group": { "enum": ["ecosystem", "community"] },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "resources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "url", "description", "official", "lifecycle"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
                "description": { "type": "string", "minLength": 10, "maxLength": 280 },
                "official": { "type": "boolean" },
                "lifecycle": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": { "enum": ["build", "observe", "evaluate", "deploy"] }
                }
              }
            }
          }
        }
      }
    }
  }
}
